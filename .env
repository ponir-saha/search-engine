OPENAI_API_KEY=
SPRING_PROFILES_ACTIVE=local

JDBC_URL=jdbc:postgresql://127.0.0.1:5432/products_db
R2DBC_URL=r2dbc:postgresql://127.0.0.1:5432/products_db
POSTGRES_USER=pguser
POSTGRES_PASSWORD=pgpass

VECTORDB_URL=http://127.0.0.1:8085
VECTORDB_TYPE=weaviate
OPENSEARCH_URL=http://127.0.0.1:9200
OPENSEARCH_INDEX_PRODUCTS=products

KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9093
APP_KAFKA_TOPIC=dbserver1.public.products
APP_KAFKA_GROUP_ID=search-engine-group
APP_KAFKA_DLQ_TOPIC=dbserver1.public.products.dlq
APP_KAFKA_CONCURRENCY=1
APP_KAFKA_RETRY_MAX_ATTEMPTS=3
APP_KAFKA_RETRY_INTERVAL_MS=2000

APP_BOOTSTRAP_ENABLED=true
APP_BOOTSTRAP_DATASET=classpath:data/products.tsv
APP_BOOTSTRAP_WAIT_FOR_INDEXES=true
APP_BOOTSTRAP_WAIT_TIMEOUT=PT15M

OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0
LOG_FILE=logs/search-engine.log

# Optional local overrides
# APP_PORT=8082
# LOCAL_HTTP_HOSTS="127.0.0.1 localhost 0.0.0.0"
# KAFKA_CONNECT_BASE_URL=http://127.0.0.1:8083
