OPENAI_API_KEY=your-openai-api-key
VECTORDB_URL=http://localhost:8085
VECTORDB_TYPE=weaviate
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX_PRODUCTS=products
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
APP_BOOTSTRAP_ENABLED=true
APP_BOOTSTRAP_RESET=true
APP_BOOTSTRAP_DATASET=classpath:data/products.tsv
APP_BOOTSTRAP_WAIT_FOR_INDEXES=true
APP_BOOTSTRAP_WAIT_TIMEOUT=PT15M
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0
LOG_FILE=logs/search-engine.log
